[Unit]
Description=Zabbix Proxy Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=YOUR_USER
Group=YOUR_USER
WorkingDirectory=/data/local/infra-assistant/zabbix-proxy
EnvironmentFile=/data/local/infra-assistant/.env
ExecStart=/data/local/infra-assistant/zabbix-proxy/venv/bin/python app.py
Restart=always
RestartSec=10
StandardOutput=append:/data/local/infra-assistant/logs/zabbix-proxy.log
StandardError=append:/data/local/infra-assistant/logs/zabbix-proxy.log

[Install]
WantedBy=multi-user.target
