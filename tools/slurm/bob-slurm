#!/usr/bin/env bash
# bob-slurm: restricted Slurm wrapper for automation clients (e.g. Bob).
# Intended to be invoked remotely via SSH + sudo from a controlled caller.

set -euo pipefail

MAX_REASON_LEN=120
MAX_SAMPLE_NODES=50

json_escape() {
  local s="${1-}"
  s=${s//\\/\\\\}
  s=${s//\"/\\\"}
  s=${s//$'\n'/\\n}
  s=${s//$'\r'/\\r}
  s=${s//$'\t'/\\t}
  printf '%s' "$s"
}

emit_error() {
  local code="$1"
  local message="$2"
  printf '{"ok":false,"error":"%s","code":%s}\n' "$(json_escape "$message")" "$code"
  exit "$code"
}

require_cmd() {
  local cmd="$1"
  command -v "$cmd" >/dev/null 2>&1 || emit_error 127 "Required command not found: $cmd"
}

valid_node() {
  local node="$1"
  [[ "$node" =~ ^[A-Za-z0-9_.:-]+$ ]]
}

valid_partition() {
  local part="$1"
  [[ "$part" =~ ^[A-Za-z0-9_.-]+$ ]]
}

valid_reason() {
  local reason="$1"
  [[ "$reason" =~ ^[A-Za-z0-9._:@/#\ -]+$ ]]
}

normalize_reason() {
  local reason="$1"
  reason="$(printf '%s' "$reason" | tr -s ' ' ' ')"
  reason="${reason#"${reason%%[![:space:]]*}"}"
  reason="${reason%"${reason##*[![:space:]]}"}"
  printf '%s' "$reason"
}

summary_action() {
  local partition="${1-}"
  local -a sinfo_cmd

  sinfo_cmd=(sinfo -h -N -o "%N|%t|%P")
  if [[ -n "$partition" ]]; then
    sinfo_cmd=(sinfo -p "$partition" -h -N -o "%N|%t|%P")
  fi

  local output
  output="$("${sinfo_cmd[@]}" 2>/dev/null || true)"
  [[ -n "$output" ]] || emit_error 4 "No Slurm nodes found (or query failed)"

  local total=0 idle=0 alloc=0 mixed=0 down=0 drain=0 other=0
  local sample_count=0
  local sample_json=""

  while IFS='|' read -r node state part; do
    [[ -n "$node" ]] || continue
    total=$((total + 1))

    case "${state^^}" in
      IDLE*) idle=$((idle + 1)) ;;
      ALLOC*) alloc=$((alloc + 1)) ;;
      MIX*) mixed=$((mixed + 1)) ;;
      DRAIN*|DRAINING*) drain=$((drain + 1)) ;;
      DOWN*|FAIL*|FUTR*|UNK*|INVAL*) down=$((down + 1)) ;;
      *) other=$((other + 1)) ;;
    esac

    if (( sample_count < MAX_SAMPLE_NODES )); then
      local item
      item=$(printf '{"node":"%s","state":"%s","partition":"%s"}' \
        "$(json_escape "$node")" \
        "$(json_escape "$state")" \
        "$(json_escape "$part")")
      if [[ -n "$sample_json" ]]; then
        sample_json="${sample_json},${item}"
      else
        sample_json="${item}"
      fi
      sample_count=$((sample_count + 1))
    fi
  done <<< "$output"

  local part_name="all"
  [[ -n "$partition" ]] && part_name="$partition"

  printf '{"ok":true,"action":"summary","partition":"%s","counts":{"total":%d,"idle":%d,"alloc":%d,"mixed":%d,"drain":%d,"down":%d,"other":%d},"sample":[%s]}\n' \
    "$(json_escape "$part_name")" \
    "$total" "$idle" "$alloc" "$mixed" "$drain" "$down" "$other" "$sample_json"
}

node_status_action() {
  local node="$1"
  valid_node "$node" || emit_error 2 "Invalid node format"

  local line
  line="$(sinfo -h -N -n "$node" -o "%N|%t|%P" 2>/dev/null | head -n 1 || true)"
  [[ -n "$line" ]] || emit_error 4 "Node not found: $node"

  local node_name state partition
  IFS='|' read -r node_name state partition <<< "$line"

  local details
  details="$(scontrol show node "$node" 2>/dev/null || true)"
  local reason=""
  if [[ -n "$details" ]]; then
    reason="$(printf '%s\n' "$details" | tr ' ' '\n' | sed -n 's/^Reason=//p' | head -n 1)"
  fi

  printf '{"ok":true,"action":"node-status","node":"%s","state":"%s","partition":"%s","reason":"%s"}\n' \
    "$(json_escape "$node_name")" \
    "$(json_escape "$state")" \
    "$(json_escape "$partition")" \
    "$(json_escape "$reason")"
}

drain_action() {
  local node="$1"
  local reason="$2"

  valid_node "$node" || emit_error 2 "Invalid node format"
  reason="$(normalize_reason "$reason")"
  [[ -n "$reason" ]] || emit_error 2 "Drain reason is required"
  (( ${#reason} <= MAX_REASON_LEN )) || emit_error 2 "Drain reason too long (max ${MAX_REASON_LEN})"
  valid_reason "$reason" || emit_error 2 "Drain reason contains unsupported characters"

  if [[ "$EUID" -ne 0 ]]; then
    emit_error 13 "Drain requires root privileges (configure sudoers for bob-slurm)"
  fi

  scontrol update "NodeName=${node}" State=DRAIN "Reason=${reason}" >/dev/null
  node_status_action "$node"
}

resume_action() {
  local node="$1"
  valid_node "$node" || emit_error 2 "Invalid node format"

  if [[ "$EUID" -ne 0 ]]; then
    emit_error 13 "Resume requires root privileges (configure sudoers for bob-slurm)"
  fi

  scontrol update "NodeName=${node}" State=RESUME >/dev/null
  node_status_action "$node"
}

queue_action() {
  local user="${1-}"

  if [[ -n "$user" ]]; then
    [[ "$user" =~ ^[a-zA-Z0-9_-]+$ ]] || emit_error 2 "Invalid username format"
    local output
    output="$(squeue -u "$user" -o "%i|%j|%u|%T|%M|%l|%D|%R" -h 2>/dev/null || true)"
  else
    local output
    output="$(squeue -o "%i|%j|%u|%T|%M|%l|%D|%R" -h 2>/dev/null || true)"
  fi

  [[ -n "$output" ]] || emit_error 4 "No jobs found"

  local job_json=""
  local count=0
  while IFS='|' read -r jobid name user state time limit nodes nodelist; do
    [[ -n "$jobid" ]] || continue
    count=$((count + 1))
    local item
    item=$(printf '{"jobid":"%s","name":"%s","user":"%s","state":"%s","time":"%s","limit":"%s","nodes":"%s","nodelist":"%s"}' \
      "$(json_escape "$jobid")" \
      "$(json_escape "$name")" \
      "$(json_escape "$user")" \
      "$(json_escape "$state")" \
      "$(json_escape "$time")" \
      "$(json_escape "$limit")" \
      "$(json_escape "$nodes")" \
      "$(json_escape "$nodelist")")
    if [[ -n "$job_json" ]]; then
      job_json="${job_json},${item}"
    else
      job_json="${item}"
    fi
  done <<< "$output"

  printf '{"ok":true,"action":"queue","count":%d,"jobs":[%s]}\n' "$count" "$job_json"
}

job_action() {
  local jobid="$1"
  [[ "$jobid" =~ ^[0-9]+$ ]] || emit_error 2 "Invalid job ID format"

  local output
  output="$(scontrol show job "$jobid" 2>/dev/null || true)"
  [[ -n "$output" ]] || emit_error 4 "Job not found: $jobid"

  printf '{"ok":true,"action":"job","jobid":"%s","details":"%s"}\n' \
    "$(json_escape "$jobid")" \
    "$(json_escape "$output")"
}

history_action() {
  local user="${1-}"
  local state="${2-}"
  local hours="${3:-24}"
  local limit="${4:-50}"

  # Validate inputs
  if [[ -n "$user" ]]; then
    [[ "$user" =~ ^[a-zA-Z0-9_-]+$ ]] || emit_error 2 "Invalid username format"
  fi
  if [[ -n "$state" ]]; then
    [[ "$state" =~ ^[A-Z_]+$ ]] || emit_error 2 "Invalid state format"
  fi
  [[ "$hours" =~ ^[0-9]+$ ]] || emit_error 2 "Invalid hours format"
  [[ "$limit" =~ ^[0-9]+$ ]] || emit_error 2 "Invalid limit format"
  (( limit <= 500 )) || emit_error 2 "Limit too high (max 500)"

  # Build sacct command
  local -a sacct_cmd
  local starttime
  starttime=$(date -d "$hours hours ago" +%Y-%m-%dT%H:%M:%S 2>/dev/null || date -v-${hours}H +%Y-%m-%dT%H:%M:%S 2>/dev/null)
  [[ -n "$starttime" ]] || emit_error 127 "Failed to calculate start time"

  sacct_cmd=(sacct --starttime="$starttime" --format=JobID,JobName,User,State,ExitCode,Start,End,Elapsed,NodeList -P -n)

  if [[ -n "$user" ]]; then
    sacct_cmd+=(--user="$user")
  fi
  if [[ -n "$state" ]]; then
    sacct_cmd+=(--state="$state")
  fi

  local output
  output=$("${sacct_cmd[@]}" 2>/dev/null || true)

  # Process output into JSON array (empty array if no results)
  local job_json=""
  local count=0

  if [[ -n "$output" ]]; then
    while IFS='|' read -r jobid name user state exitcode start end elapsed nodelist; do
      [[ -n "$jobid" ]] || continue
      # Skip sub-jobs (e.g., 123.batch, 123.0)
      [[ "$jobid" =~ \. ]] && continue

      (( count >= limit )) && break
      count=$((count + 1))

      local item
      item=$(printf '{"jobid":"%s","name":"%s","user":"%s","state":"%s","exitcode":"%s","start":"%s","end":"%s","elapsed":"%s","nodelist":"%s"}' \
        "$(json_escape "$jobid")" \
        "$(json_escape "$name")" \
        "$(json_escape "$user")" \
        "$(json_escape "$state")" \
        "$(json_escape "$exitcode")" \
        "$(json_escape "$start")" \
        "$(json_escape "$end")" \
        "$(json_escape "$elapsed")" \
        "$(json_escape "$nodelist")")

      if [[ -n "$job_json" ]]; then
        job_json="${job_json},${item}"
      else
        job_json="${item}"
      fi
    done <<< "$output"
  fi

  # Return success even with zero results
  printf '{"ok":true,"action":"history","count":%d,"hours":%d,"jobs":[%s]}\n' \
    "$count" "$hours" "$job_json"
}

usage() {
  cat <<'USAGE'
Usage:
  bob-slurm summary [--partition PARTITION]
  bob-slurm node-status --node NODE
  bob-slurm drain --node NODE --reason REASON
  bob-slurm resume --node NODE
  bob-slurm queue [--user USERNAME]
  bob-slurm job --jobid JOBID
  bob-slurm history [--user USERNAME] [--state STATE] [--hours HOURS] [--limit LIMIT]
USAGE
}

main() {
  local action="${1-}"
  [[ -n "$action" ]] || { usage; emit_error 2 "Missing action"; }
  if [[ "$action" == "-h" || "$action" == "--help" || "$action" == "help" ]]; then
    usage
    exit 0
  fi
  shift || true

  require_cmd sinfo
  require_cmd scontrol
  require_cmd sed
  require_cmd tr

  case "$action" in
    summary)
      local partition=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --partition)
            shift
            [[ $# -gt 0 ]] || emit_error 2 "Missing partition value"
            partition="$1"
            ;;
          *)
            emit_error 2 "Unknown argument for summary: $1"
            ;;
        esac
        shift || true
      done
      if [[ -n "$partition" ]]; then
        valid_partition "$partition" || emit_error 2 "Invalid partition format"
      fi
      summary_action "$partition"
      ;;

    node-status)
      local node=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --node)
            shift
            [[ $# -gt 0 ]] || emit_error 2 "Missing node value"
            node="$1"
            ;;
          *)
            emit_error 2 "Unknown argument for node-status: $1"
            ;;
        esac
        shift || true
      done
      [[ -n "$node" ]] || emit_error 2 "node-status requires --node"
      node_status_action "$node"
      ;;

    drain)
      local node=""
      local reason=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --node)
            shift
            [[ $# -gt 0 ]] || emit_error 2 "Missing node value"
            node="$1"
            ;;
          --reason)
            shift
            [[ $# -gt 0 ]] || emit_error 2 "Missing reason value"
            reason="$1"
            ;;
          *)
            emit_error 2 "Unknown argument for drain: $1"
            ;;
        esac
        shift || true
      done
      [[ -n "$node" ]] || emit_error 2 "drain requires --node"
      [[ -n "$reason" ]] || emit_error 2 "drain requires --reason"
      drain_action "$node" "$reason"
      ;;

    resume)
      local node=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --node)
            shift
            [[ $# -gt 0 ]] || emit_error 2 "Missing node value"
            node="$1"
            ;;
          *)
            emit_error 2 "Unknown argument for resume: $1"
            ;;
        esac
        shift || true
      done
      [[ -n "$node" ]] || emit_error 2 "resume requires --node"
      resume_action "$node"
      ;;

    queue)
      require_cmd squeue
      local user=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --user)
            shift
            [[ $# -gt 0 ]] || emit_error 2 "Missing user value"
            user="$1"
            ;;
          *)
            emit_error 2 "Unknown argument for queue: $1"
            ;;
        esac
        shift || true
      done
      queue_action "$user"
      ;;

    job)
      local jobid=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --jobid)
            shift
            [[ $# -gt 0 ]] || emit_error 2 "Missing jobid value"
            jobid="$1"
            ;;
          *)
            emit_error 2 "Unknown argument for job: $1"
            ;;
        esac
        shift || true
      done
      [[ -n "$jobid" ]] || emit_error 2 "job requires --jobid"
      job_action "$jobid"
      ;;

    history)
      require_cmd sacct
      local user=""
      local state=""
      local hours="24"
      local limit="50"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --user)
            shift
            [[ $# -gt 0 ]] || emit_error 2 "Missing user value"
            user="$1"
            ;;
          --state)
            shift
            [[ $# -gt 0 ]] || emit_error 2 "Missing state value"
            state="$1"
            ;;
          --hours)
            shift
            [[ $# -gt 0 ]] || emit_error 2 "Missing hours value"
            hours="$1"
            ;;
          --limit)
            shift
            [[ $# -gt 0 ]] || emit_error 2 "Missing limit value"
            limit="$1"
            ;;
          *)
            emit_error 2 "Unknown argument for history: $1"
            ;;
        esac
        shift || true
      done
      history_action "$user" "$state" "$hours" "$limit"
      ;;

    *)
      usage
      emit_error 2 "Unknown action: $action"
      ;;
  esac
}

main "$@"
