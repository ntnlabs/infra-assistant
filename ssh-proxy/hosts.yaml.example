# SSH Proxy Hosts Configuration
# =============================
# Copy this file to hosts.yaml and configure your hosts:
#   cp hosts.yaml.example hosts.yaml
#   nano hosts.yaml
#
# This file is .gitignore'd - safe to put real hostnames here.

# Allowed target hosts
# The "name" is what the agent uses to refer to them.
hosts:
  # Example configuration:
  #
  # - name: "webserver1"
  #   hostname: "192.168.1.10"
  #   username: "monitoring"
  #   key_file: "/opt/infra-assistant/keys/monitoring_key"
  #
  # - name: "dbserver1"
  #   hostname: "192.168.1.20"
  #   username: "monitoring"
  #   key_file: "/opt/infra-assistant/keys/monitoring_key"
  #
  # - name: "router1"
  #   hostname: "192.168.1.1"
  #   username: "admin"
  #   key_file: "/opt/infra-assistant/keys/network_key"

  - name: "localhost"
    hostname: "127.0.0.1"
    username: "monitoring"
    key_file: "/opt/infra-assistant/keys/monitoring_key"
