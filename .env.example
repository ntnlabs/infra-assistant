# Infra Assistant Environment Configuration
# ==========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   nano .env
#
# NEVER commit .env to git!

# ===================
# Ollama Configuration
# ===================
# URL where Ollama is running (use actual server IP, not localhost)
OLLAMA_URL=http://10.40.8.46:11434
# Model to use for responses
OLLAMA_MODEL=llama3.1:8b
# Temperature (0.0-1.0): lower = more factual, higher = more creative
OLLAMA_TEMPERATURE=0.3
# Context window (tokens): 2048, 4096, 8192, 16384, 32768, 65536, 128000
# mistral-nemo supports up to 128k tokens
# Recommended: 16384 for normal use, 32768 for large job queues (60+ jobs)
# Larger = can handle more tool results, uses more VRAM
OLLAMA_NUM_CTX=16384

# Note: Ollama service itself is configured via systemd at /etc/systemd/system/ollama.service
# GPU selection (CUDA_VISIBLE_DEVICES=1) is set in the systemd service file

# ===================
# SSH Proxy (Independent Command Validator)
# ===================
# Bot requests commands via SSH Proxy, which validates independently
# SSH Proxy has its own allowlists (hosts.yaml, commands.yaml)
SSH_PROXY_URL=http://localhost:5001
SSH_PROXY_TOKEN=CHANGE_THIS_GENERATE_WITH_openssl_rand_hex_32

# Note: Allowed hosts and commands are configured in ssh-proxy/hosts.yaml
#       and ssh-proxy/commands.yaml, NOT in this .env file.
#       This ensures Bot cannot bypass validation.

# ===================
# Slurm Integration (optional)
# ===================
# Host alias from ssh-proxy/hosts.yaml that points to Slurm controller/master
SLURM_MASTER_HOST=
# Wrapper command installed on Slurm master
# If Bob runs as root, use direct wrapper path (no sudo)
# For non-root deployments, you can set: sudo -n /usr/local/bin/bob-slurm
SLURM_WRAPPER_COMMAND=/usr/local/bin/bob-slurm
# Optional default partition filter for summary queries
SLURM_DEFAULT_PARTITION=

# ===================
# Rocket.Chat Configuration
# ===================
RC_URL=https://your-rocketchat.company.com
RC_USERNAME=infra-bot
RC_PASSWORD=CHANGE_THIS_RC_BOT_PASSWORD
RC_CHANNELS=infra-alerts
# Comma-separated list of channels, e.g.: infra-alerts,noc,devops

# User filter (comma-separated, empty = allow all)
RC_ALLOWED_USERS=
# Example: RC_ALLOWED_USERS=peter,admin,oncall

# Prefix requirement (empty = respond to all messages in channels)
# Not required for DMs
RC_PREFIX=@infra

# ===================
# Zabbix Configuration
# ===================
ZABBIX_URL=https://your-zabbix.company.com
ZABBIX_USER=api-user
ZABBIX_PASSWORD=CHANGE_THIS_ZABBIX_PASSWORD
ZABBIX_PROXY_PORT=5002
ZABBIX_PROXY_TOKEN=CHANGE_THIS_GENERATE_WITH_openssl_rand_hex_32
ZABBIX_PROXY_URL=http://localhost:5002

# Zabbix Poller - proactive alerting
ALERT_MIN_SEVERITY=3
# 0=Not classified, 1=Info, 2=Warning, 3=Average, 4=High, 5=Disaster
RC_ALERT_WEBHOOK_URL=
# Get from RC: Integrations → New Integration → Incoming Webhook

# ===================
# Graylog Configuration (future)
# ===================
# GRAYLOG_URL=https://your-graylog.company.com
# GRAYLOG_TOKEN=CHANGE_THIS_GRAYLOG_TOKEN
# GRAYLOG_PROXY_PORT=5003

# ===================
# Optional Settings
# ===================
# Conversation timeout in seconds (0 = never expire)
CONVERSATION_TIMEOUT=3600

# Poll interval for RC messages (seconds)
POLL_INTERVAL=2

# How often to refresh DM room list from Rocket.Chat (seconds)
DM_REFRESH_INTERVAL=60

# Maximum Ollama tool-calling iterations per query (default: 5, max: 25)
# Prevents infinite loops. Most queries use 1-2 iterations.
MAX_OLLAMA_ITERATIONS=5

# Debug mode (true/false)
DEBUG=false
